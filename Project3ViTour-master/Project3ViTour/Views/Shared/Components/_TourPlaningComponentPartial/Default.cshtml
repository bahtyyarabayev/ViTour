@using Project3ViTour.Dtos.TourPlanDtos
@model List<ResultTourPlanDto>

<style>
    :root {
        --primary-green: #10b981; /* Canlı Zümrüt Yeşili */
        --dark-green: #064e3b;
        --light-green: #ecfdf5;
        --accent-green: #34d399;
        --text-slate: #334155;
    }

    .tour-full-width-wrapper {
        width: 100%;
        padding: 20px 0;
        font-family: 'Inter', sans-serif;
    }

    .tour-plan-card {
        display: flex;
        width: 100%;
        background: #ffffff;
        margin-bottom: 25px;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

        .tour-plan-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(16, 185, 129, 0.1);
            border-color: var(--accent-green);
        }

    /* Sol Şerit - Gün Göstergesi */
    .day-strip {
        background: linear-gradient(180deg, var(--primary-green) 0%, var(--dark-green) 100%);
        width: 100px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: white;
        flex-shrink: 0;
    }

        .day-strip .day-text {
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            opacity: 0.9;
        }

        .day-strip .day-num {
            font-size: 2.2rem;
            font-weight: 900;
        }

    /* Sağ İçerik Alanı */
    .content-area {
        flex-grow: 1;
        padding: 30px;
        position: relative;
    }

        .content-area h3 {
            color: var(--dark-green);
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .content-area h3 i {
                color: var(--primary-green);
            }

        .content-area p {
            color: var(--text-slate);
            line-height: 1.7;
            font-size: 1rem;
            margin-bottom: 20px;
            max-width: 95%; /* Çok uzun satırları engellemek için */
        }

    /* Yeşil Madde İşaretleri (Grid) */
    .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 15px;
    }

    .feature-item {
        background: var(--light-green);
        padding: 12px 18px;
        border-radius: 12px;
        color: var(--dark-green);
        font-weight: 600;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 12px;
        border: 1px solid rgba(16, 185, 129, 0.1);
    }

        .feature-item i {
            color: var(--primary-green);
            font-size: 1.1rem;
        }

    /* Mobil Düzen */
    @@media (max-width: 768px) {
        .tour-plan-card {
            flex-direction: column;
        }

        .day-strip {
            width: 100%;
            height: 60px;
            flex-direction: row;
            gap: 8px;
        }

        .content-area {
            padding: 20px;
        }

        .feature-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="tour-full-width-wrapper">
    @foreach (var plan in (Model ?? new List<ResultTourPlanDto>()).OrderBy(x => x.DayNumber))
    {
        <div class="tour-plan-card">
            <div class="day-strip">
                <span class="day-text">GÜN</span>
                <span class="day-num">@plan.DayNumber</span>
            </div>

            <div class="content-area">
                <h3>
                    <i class="bi bi-patch-check-fill"></i>
                    @plan.Title
                </h3>

                <p>@plan.Description</p>

                @if (plan.Items != null && plan.Items.Any(i => !string.IsNullOrWhiteSpace(i)))
                {
                    <div class="feature-grid">
                        @foreach (var item in plan.Items)
                        {
                            if (!string.IsNullOrWhiteSpace(item))
                            {
                                <div class="feature-item">
                                    <i class="bi bi-geo-alt"></i>
                                    <span>@item</span>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>