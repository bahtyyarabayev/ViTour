@using Project3ViTour.Dtos.TourImageDtos
@model List<ResultGalleryImageDto>

<div class="row mb-40 image-gallery-single">
    @for (int i = 0; i < Model.Count; i++)
    {
        if (i == 0) // İlk resim büyük alan (col-sm-6)
        {
            <div class="col-12 col-sm-6">
                <img src="@Model[i].ImageUrl" alt="image" style="width:100%; height:300px; object-fit:cover;">
            </div>
        }
        else // Diğerleri yanındaki küçük alanlar (col-sm-3)
        {
            <div class="col-6 col-sm-3">
                <img src="@Model[i].ImageUrl" alt="image" style="width:100%; height:300px; object-fit:cover;">
            </div>
        }
    }
</div>