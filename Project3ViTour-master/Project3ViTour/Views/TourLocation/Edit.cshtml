@model Project3ViTour.Dtos.TourLocationDtos.UpdateTourLocationDto

@{
    ViewData["Title"] = "Lokasyon Düzenleme";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h4 class="mb-4 fw-semibold">Lokasyon Güncelle</h4>

                <form asp-action="Edit" asp-controller="TourLocation" method="post">
                    <input asp-for="TourLocationId" type="hidden" />
                    <input asp-for="TourId" type="hidden" />

                    <div class="mb-3">
                        <label class="form-label text-muted small">Resim URL</label>
                        <div class="d-flex gap-2">
                            <input asp-for="ImageUrl" class="form-control"
                                   placeholder="https://..."
                                   oninput="previewImage(this.value)" />
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    onclick="previewImage(document.getElementById('ImageUrl').value)">
                                Önizle
                            </button>
                        </div>
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        <div class="mt-3" id="preview-container">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img id="preview-img" src="@Model.ImageUrl"
                                 alt="önizleme"
                                 class="rounded-3"
                                 style="width:100%; max-height:250px; object-fit:cover;" />
                            }
                            else
                            {
                                <img id="preview-img" src=""
                                 alt="önizleme"
                                 class="rounded-3 d-none"
                                 style="width:100%; max-height:250px; object-fit:cover;" />
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="5"
                                  placeholder="Lokasyon açıklaması..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small">Maddeler</label>
                        <div id="items-container">
                            @if (Model.Items != null)
                            {
                                @for (int i = 0; i < Model.Items.Count; i++)
                                {
                                    <div class="input-group mb-2">
                                        <input type="text" name="Items[@i]"
                                       class="form-control"
                                       value="@Model.Items[i]"
                                       placeholder="Madde giriniz..." />
                                        <button type="button" class="btn btn-outline-danger"
                                        onclick="removeItem(this)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                }
                            }
                        </div>
                        <button type="button" class="btn btn-outline-secondary btn-sm mt-1"
                                onclick="addItem()">
                            + Madde Ekle
                        </button>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Güncelle</button>
                        <a asp-action="Index" asp-controller="TourLocation"
                           class="btn btn-outline-secondary px-4">İptal</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<script>
    let itemIndex = @(Model.Items?.Count ?? 0);

    function previewImage(url) {
        const img = document.getElementById('preview-img');
        if (url && url.trim() !== '') {
            img.src = url;
            img.classList.remove('d-none');
            img.onerror = function () {
                img.classList.add('d-none');
            };
        } else {
            img.classList.add('d-none');
        }
    }

    function addItem() {
        const container = document.getElementById('items-container');
        const div = document.createElement('div');
        div.className = 'input-group mb-2';
        div.innerHTML = `
                <input type="text" name="Items[${itemIndex}]" class="form-control"
                       placeholder="Madde giriniz..." />
                <button type="button" class="btn btn-outline-danger" onclick="removeItem(this)">
                    <i class="bi bi-trash"></i>
                </button>
            `;
        container.appendChild(div);
        itemIndex++;
    }

    function removeItem(btn) {
        const container = document.getElementById('items-container');
        if (container.children.length > 1) {
            btn.closest('.input-group').remove();
        }
    }
</script>