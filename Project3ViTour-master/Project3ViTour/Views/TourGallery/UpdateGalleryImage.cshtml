@model Project3ViTour.Dtos.TourImageDtos.GetGalleryImageByIdDto
@{
    ViewData["Title"] = "Görsel Düzenleme";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

@section Styles {
    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.95);
            --gradient-primary: linear-gradient(135deg, #6366f1 0%, #4338ca 100%);
        }

        .update-container {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: 2rem;
            align-items: start;
        }

        .form-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        }

        .sticky-preview {
            position: sticky;
            top: 20px;
        }

        .preview-wrapper {
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.2);
            background: #f1f5f9;
            aspect-ratio: 3/4;
        }

        #imagePreview {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .custom-input-group {
            margin-bottom: 1.5rem;
        }

            .custom-input-group label {
                display: block;
                margin-bottom: 0.5rem;
                font-weight: 600;
                color: #1e293b;
            }

        .modern-input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            outline: none;
        }

            .modern-input:focus {
                border-color: #6366f1;
                box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            }

        .btn-modern-save {
            background: var(--gradient-primary);
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 14px;
            font-weight: 600;
            width: 100%;
            cursor: pointer;
        }

        @@media (max-width: 992px) {
            .update-container {
                grid-template-columns: 1fr;
            }

            .sticky-preview {
                position: static;
                order: -1;
            }
        }
    </style>
}

    <div class="container-fluid py-4">
        <div class="update-container">

            <div class="form-glass-card">
                <div class="mb-4">
                    <h2 class="fw-bold mb-1">Görseli Güncelle</h2>
                    <p class="text-muted small">ID: #@Model.GalleryImageId</p>
                </div>

                <form asp-controller="TourGallery" asp-action="UpdateGalleryImage" method="post">
                    <input type="hidden" asp-for="GalleryImageId" />

                    <div class="custom-input-group">
                        <label>Görsel Başlığı</label>
                        <input class="modern-input" asp-for="Title" placeholder="Görsel başlığı..." />
                    </div>

                    <div class="custom-input-group">
                        <label>Görsel URL Adresi</label>
                        <input class="modern-input" asp-for="ImageUrl" id="urlInput" placeholder="https://..." />
                    </div>

                    <div class="custom-input-group">
                        <label>İlişkili Tur</label>
                        <select class="modern-input" asp-for="TourId" asp-items="@(ViewBag.Tours as SelectList)">
                            <option value="">Tur Listesinden Seçin</option>
                        </select>
                    </div>

                    <div class="row g-2 mt-4">
                        <div class="col-8">
                            <button type="submit" class="btn-modern-save">
                                <i class="bi bi-check-circle me-2"></i>Değişiklikleri Kaydet
                            </button>
                        </div>
                        <div class="col-4">
                            <a href="/GalleryImage/Index" class="btn btn-light w-100" style="padding: 14px; border-radius: 14px; border: 2px solid #e2e8f0; font-weight: 600;">
                                İptal
                            </a>
                        </div>
                    </div>
                </form>
            </div>

            <div class="sticky-preview">
                <div class="preview-wrapper">
                    <img id="imagePreview" src="@Model.ImageUrl" alt="Preview"
                     onerror="this.src='https://via.placeholder.com/600x800?text=Gecersiz+Gorsel+URL'" />
                </div>
                <div class="text-center mt-3">
                    <p class="text-muted small">Canlı önizleme (3:4 Oranı)</p>
                </div>
            </div>

        </div>
    </div>

    @section Scripts {
    <script>
        // DOM yüklendiğinde çalışacak güvenli script
        document.addEventListener("DOMContentLoaded", function () {
            const urlInput = document.querySelector('#urlInput');
            const imgPreview = document.querySelector('#imagePreview');

            // URL Değiştikçe Resmi Güncelle
            urlInput?.addEventListener('input', (e) => {
                const url = e.target.value.trim();
                imgPreview.src = url || 'https://via.placeholder.com/600x800?text=URL+Bekleniyor';
            });
        });
    </script>
}