@using Project3ViTour.Dtos.TourImageDtos
@model CreateGalleryImageDto
@{
    ViewData["Title"] = "CreateGalleryImage";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

@section Styles {
    <style>
        /* Modern Kart Tasarımı */
        .card-surface {
            background: #fff;
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
            overflow: hidden;
        }

        /* Form Bölümü Sol Arkaplan */
        .form-section {
            padding: 40px;
            background: #fff;
        }

        /* Preview Bölümü Sağ Arkaplan */
        .preview-section {
            padding: 40px;
            background: #f8faff;
            border-left: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .btn-accent {
            background: var(--accent);
            border: none;
            color: #fff;
            border-radius: 10px;
            padding: 12px 24px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-accent:hover {
                background: var(--accent-dk);
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .form-label-custom {
            font-weight: 700;
            font-size: 0.85rem;
            color: #495057;
            margin-bottom: 8px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-control-custom {
            border-radius: 10px;
            border: 2px solid #edf2f7;
            padding: 12px 15px;
            transition: all 0.2s;
        }

            .form-control-custom:focus {
                border-color: var(--accent);
                box-shadow: none;
                background-color: #fff;
            }

        /* Preview Görseli */
        .image-wrapper {
            position: relative;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            background: #eee;
            aspect-ratio: 16/10;
        }

        .preview-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s;
        }

        .image-badge {
            position: absolute;
            top: 15px;
            left: 15px;
            background: rgba(255,255,255,0.9);
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            color: var(--accent);
        }
    </style>
}

    <div class="container-fluid py-4">
        <div class="row mb-4">
            <div class="col-12 d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-1">Yeni Görsel Tanımla</h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="/admin/galleryimages" class="text-muted text-decoration-none">Galeri</a></li>
                            <li class="breadcrumb-item active text-primary fw-bold">Ekle</li>
                        </ol>
                    </nav>
                </div>
                <a href="/admin/galleryimages" class="btn btn-light rounded-pill px-4">
                    <i class="bi bi-arrow-left me-2"></i>Geri Dön
                </a>
            </div>
        </div>

        <div class="card-surface">
            <form asp-controller="TourGallery" asp-action="CreateGalleryImage" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-0">

                    <div class="col-lg-7 form-section">
                        <div class="mb-4">
                            <label class="form-label-custom">Görsel Başlığı</label>
                            <input class="form-control form-control-custom" asp-for="Title" placeholder="Örn: Kapadokya Balon Turu" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label-custom">Resim Bağlantısı (URL)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-link-45deg"></i></span>
                                <input class="form-control form-control-custom" asp-for="ImageUrl" id="imageUrlInput" placeholder="https://resim-url-adresi.com/resim.jpg" />
                            </div>
                            <div class="mt-2 text-muted small">Desteklenen: JPG, PNG, WebP (Cloudinary, CDN vb.)</div>
                        </div>

                        <div class="mb-5">
                            <label class="form-label-custom">İlişkili Tur</label>
                            @* Sadece null değilse ve içinde veri varsa Select oluştur *@
                        @if (ViewBag.Tours != null && (ViewBag.Tours as List<SelectListItem>)?.Any() == true)
                        {
                            <select class="form-select form-control-custom" asp-for="TourId"
                                asp-items="@(ViewBag.Tours as List<SelectListItem>)">
                                <option value="" selected disabled>— Bir Tur Seçiniz —</option>
                            </select>
                        }
                        else
                        {
                            @* Veri gelmezse hata fırlatmak yerine düz input göster *@
                            <input class="form-control form-control-custom" asp-for="TourId" placeholder="Tur ID bilgisini el ile girin" />
                            <small class="text-danger">Uyarı: Tur listesi yüklenemedi!</small>
                        }
                    </div>

                    <div class="pt-3 border-top">
                        <button type="submit" class="btn btn-accent px-5 py-3">
                            <i class="bi bi-cloud-upload me-2"></i>Görseli Galeriye Kaydet
                        </button>
                    </div>
                </div>

                <div class="col-lg-5 preview-section">
                    <div class="text-center mb-3">
                        <h6 class="fw-bold text-secondary">CANLI ÖNİZLEME</h6>
                    </div>

                    <div class="image-wrapper">
                        <div class="image-badge">LIVE PREVIEW</div>
                        <img id="imagePreview"
                             class="preview-img"
                             src="https://via.placeholder.com/800x500?text=Resim+Bekleniyor"
                             alt="Görsel Önizleme" />
                    </div>

                    <div class="mt-4 p-3 bg-white rounded-3 border">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="bi bi-info-circle-fill text-primary fs-4"></i>
                            </div>
                            <div class="ms-3">
                                <p class="mb-0 small text-muted">URL alanına geçerli bir bağlantı girdiğinizde görsel otomatik olarak burada belirecektir.</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const urlInput = document.getElementById('imageUrlInput') || document.getElementById('ImageUrl');
        const preview = document.getElementById('imagePreview');

        function setPreview(url) {
            const fallback = 'https://via.placeholder.com/800x500?text=Gecersiz+Resim+URL';

            if (!preview) return;

            if (!url || url.trim().length < 5) {
                preview.src = 'https://via.placeholder.com/800x500?text=Resim+Bekleniyor';
                return;
            }

            preview.src = url;
        }

        if (urlInput) {
            setPreview(urlInput.value);
            urlInput.addEventListener('input', (e) => setPreview(e.target.value));
        }

        preview?.addEventListener('error', () => {
            preview.src = 'https://via.placeholder.com/800x500?text=Gecersiz+Veya+Hatalı+URL';
        });
    </script>
}

